{
    "name": "ryusoh-github-io",
    "version": "1.0.0",
    "private": true,
    "description": "Personal website and portfolio",
    "scripts": {
        "lint": "npm run lint:js && npm run lint:css",
        "lint:js": "eslint . --config eslint.config.cjs --max-warnings=0 --no-warn-ignored",
        "lint:css": "stylelint \"**/*.css\" --config .stylelintrc.cjs --max-warnings=0",
        "fmt": "prettier --write . --config .prettierrc.cjs --ignore-path .prettierignore",
        "fmt:check": "prettier -c . --config .prettierrc.cjs --ignore-path .prettierignore",
        "test": "jest"
    },
    "devDependencies": {
        "@stylistic/stylelint-plugin": "^4.0.0",
        "eslint": "^9.17.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "prettier": "^3.5.2",
        "stylelint": "^16.22.0"
    }
}
