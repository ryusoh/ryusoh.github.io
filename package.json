{
    "name": "ryusoh-github-io",
    "version": "1.0.0",
    "private": true,
    "description": "Personal website and portfolio",
    "scripts": {
        "lint": "npm run lint:js && npm run lint:css",
        "lint:js": "eslint . --config eslint.config.cjs --max-warnings=0 --no-warn-ignored",
        "lint:css": "stylelint \"**/*.css\" --config .stylelintrc.cjs --max-warnings=0",
        "fmt": "prettier --write . --config .prettierrc.cjs --ignore-path .prettierignore",
        "fmt:check": "prettier -c . --config .prettierrc.cjs --ignore-path .prettierignore",
        "typecheck:js": "tsc -p jsconfig.json",
        "test": "jest --coverage"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/plugin-transform-modules-commonjs": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@stylistic/stylelint-plugin": "^5.2.1",
        "babel-jest": "^30.4.1",
        "brace-expansion": "^5.0.7",
        "eslint": "^10.7.0",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "js-yaml": "^5.2.1",
        "picomatch": "^4.0.5",
        "prettier": "^3.9.6",
        "stylelint": "^17.14.1",
        "typescript": "^7.0.2"
    }
}
